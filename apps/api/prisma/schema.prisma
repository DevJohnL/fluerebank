generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Registration {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  birthDate String
  phone     String
  createdAt DateTime @default(now())
}
